# ─────────────────────────────────────────────────────────────────────────────
# DOPPLER SECRETS REFERENCE — card-fraud-mcp-gateway
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  WARNING TO AI CODING AGENTS AND DEVELOPERS ⚠️
# DO NOT USE .env FILES FOR RUNNING THIS SERVICE.
# Secrets and environment config are managed in Doppler.
#
# To run locally:     uv run doppler-local
# To run tests:       uv run doppler-test
# To bootstrap Auth0: uv run auth0-bootstrap --yes --verbose
# To verify Auth0:    uv run auth0-verify
#
# Doppler project:  card-fraud-mcp-gateway
# Doppler configs:  local | test | prod
#
# This file documents which variables live in Doppler for each config.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8005
GATEWAY_DEBUG=false

# ── Environment (platform convention — no GATEWAY_ prefix) ───────────────────
# local → JWT bypass active, dev infra
# test  → real Auth0 M2M tokens, test infra
# prod  → real Auth0 M2M tokens, production infra
APP_ENV=local

# ── Auth — platform convention ────────────────────────────────────────────────
# local only: skip JWT validation and inject mock identity with all fraud.* scopes
# Only allowed when APP_ENV=local (config validates this; rejects bypass elsewhere)
SECURITY_SKIP_JWT_VALIDATION=true

# Auth0 tenant (shared across all card-fraud-* services)
GATEWAY_AUTH0_DOMAIN=your-tenant.us.auth0.com
GATEWAY_AUTH0_AUDIENCE=https://card-fraud-mcp-gateway

# Auth0 M2M client — auto-provisioned by: uv run auth0-bootstrap
# Stored in Doppler automatically; do not set manually.
# GATEWAY_AUTH0_CLIENT_ID=<auto-synced-by-bootstrap>
# GATEWAY_AUTH0_CLIENT_SECRET=<auto-synced-by-bootstrap>

# ── Auth0 Management (bootstrap scripts only — never in runtime) ─────────────
# AUTH0_MGMT_DOMAIN=your-tenant.us.auth0.com
# AUTH0_MGMT_CLIENT_ID=<from-auth0-management-app>
# AUTH0_MGMT_CLIENT_SECRET=<in Doppler>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
GATEWAY_PG_DSN=postgresql://fraud_user:fraud_pass@localhost:5432/fraud
GATEWAY_PG_POOL_MIN=2
GATEWAY_PG_POOL_MAX=10
GATEWAY_PG_STATEMENT_TIMEOUT_MS=5000
GATEWAY_PG_MAX_ROWS=500

# ── Redis ─────────────────────────────────────────────────────────────────────
GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_REDIS_MAX_KEYS=100
GATEWAY_REDIS_MAX_VALUE_BYTES=10000

# ── Kafka / Redpanda ──────────────────────────────────────────────────────────
GATEWAY_KAFKA_BROKERS=localhost:9092
GATEWAY_KAFKA_MAX_MESSAGES=10
GATEWAY_KAFKA_MAX_PAYLOAD_BYTES=10000

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
GATEWAY_S3_ENDPOINT=http://localhost:9000
GATEWAY_S3_ACCESS_KEY=minioadmin
GATEWAY_S3_SECRET_KEY=minioadmin
GATEWAY_S3_REGION=us-east-1
GATEWAY_S3_MAX_OBJECT_BYTES=1000000

# ── Platform API ──────────────────────────────────────────────────────────────
GATEWAY_PLATFORM_API_URL=http://localhost:8080
GATEWAY_PLATFORM_API_TOKEN=
GATEWAY_SERVICES_FILE=

# ── Access Allowlists (comma-separated or JSON array; blank = allow all) ──────
GATEWAY_PG_ALLOWED_SCHEMAS=
GATEWAY_PG_ALLOWED_TABLES=
GATEWAY_REDIS_ALLOWED_PREFIXES=
GATEWAY_KAFKA_ALLOWED_TOPICS=
GATEWAY_KAFKA_ALLOWED_GROUPS=
GATEWAY_S3_ALLOWED_BUCKETS=
GATEWAY_S3_ALLOWED_PREFIXES=

# ── Ops Domain ────────────────────────────────────────────────────────────────
# Table names only (without schema prefix - schema is determined at query time)
GATEWAY_OPS_TRANSACTIONS_TABLE=transactions
GATEWAY_OPS_CASES_TABLE=transaction_cases
GATEWAY_OPS_DECISIONS_TABLE=transaction_reviews

# ── Observability ─────────────────────────────────────────────────────────────
GATEWAY_OTEL_ENDPOINT=http://card-fraud-jaeger:4317
GATEWAY_OTEL_SERVICE_NAME=card-fraud-mcp-gateway

# Sentry error tracking (optional)
GATEWAY_SENTRY_DSN=
GATEWAY_SENTRY_ENVIRONMENT=local
GATEWAY_SENTRY_TRACES_SAMPLE_RATE=0.1
GATEWAY_SENTRY_PROFILES_SAMPLE_RATE=0.0

# ── Rate Limiting ─────────────────────────────────────────────────────────────
GATEWAY_RATE_LIMIT_RPM=120

# ── CORS (disabled by default; set per-environment in Doppler) ────────────────
# Example: GATEWAY_CORS_ORIGINS=["https://dashboard.example.com"]
GATEWAY_CORS_ORIGINS=
